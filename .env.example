# API Debian
PORT=3000

# Honkai: Star Rail
HSR_UID=YOUR_HSR_UID
HSR_REGION=prod_official_eur
HSR_USERNAME=YOUR_HSR_USERNAME

# Secret used by the Windows agent to push HoYoLAB JSON to Debian.
# Generate one on Debian with:
# openssl rand -hex 32
PUSH_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET

# Discord profile widget push
DISCORD_APP_ID=YOUR_DISCORD_APPLICATION_ID
DISCORD_USER_ID=YOUR_DISCORD_USER_ID
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN
